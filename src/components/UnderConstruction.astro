---
import { SITE_TITLE } from "../consts";
---

<div class="construct-wrapper">
  <!-- Elementos geométricos de fondo constructivista -->
  <div class="geo-shape shape-diagonal-line"></div>
  <div class="geo-shape shape-triangle"></div>
  <div class="geo-shape shape-circle"></div>
  <div class="geo-shape shape-thick-bar"></div>

  <div class="main-container">
    <div class="badge">ALERTA</div>

    <header class="header">
      <h1 class="title">
        <span class="line block-black">SITIO EN</span>
        <span class="line block-red">CONSTRUCCIÓN</span>
      </h1>
    </header>

    <div class="content-block">
      <div class="icon-arrow"></div>
      <div class="text-content">
        <p class="description">
          AQUÍ SE CONSTRUYE LA REVISTA<span class="highlight">{SITE_TITLE}</span
          >.
        </p>
        <p class="sub-description">
          LO QUE NO PUEDE FALTAR EN LA CARTERA DE LA DAMA NI EL BOLSILLO DEL
          VARÓN. COSMOPOLITICAN,TU REVISTA CON CLASE.
        </p>
      </div>
    </div>

    <div class="footer-block">
      <div class="progress-track">
        <div class="progress-fill"></div>
      </div>
      <div class="status-badge">TRABAJO EN PROGRESO_</div>
    </div>
  </div>
</div>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap");

  .construct-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: var(--color-cream); /* Cream/off-white de papel vintage */
    background-image:
      radial-gradient(var(--color-cream-dark) 1px, transparent 1px),
      radial-gradient(var(--color-cream-dark) 1px, transparent 1px);
    background-size: 20px 20px;
    background-position:
      0 0,
      10px 10px;
    color: var(--color-black);
    font-family: "Oswald", "Arial Black", Impact, sans-serif;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    box-sizing: border-box;
  }

  /* Geometría Constructivista del Fondo */
  .geo-shape {
    position: absolute;
    z-index: 0;
  }

  .shape-diagonal-line {
    width: 200vw;
    height: 15vh;
    background-color: var(--color-red); /* Rojo Revolución */
    top: 25%;
    left: -50%;
    transform: rotate(-15deg);
    border-top: 5px solid var(--color-black);
    border-bottom: 5px solid var(--color-black);
  }

  .shape-triangle {
    width: 0;
    height: 0;
    border-left: 20vw solid transparent;
    border-right: 20vw solid transparent;
    border-bottom: 40vw solid var(--color-black);
    bottom: -10vw;
    right: -5vw;
    transform: rotate(15deg);
  }

  .shape-circle {
    width: 40vh;
    height: 40vh;
    background-color: var(--color-red);
    border-radius: 50%;
    border: 8px solid var(--color-black);
    top: -10vh;
    right: 15vw;
  }

  .shape-thick-bar {
    width: 5vw;
    height: 120vh;
    background-color: var(--color-black);
    left: 10vw;
    top: -10vh;
  }

  /* Contenedor Principal */
  .main-container {
    position: relative;
    z-index: 10;
    width: 90%;
    max-width: 900px;
    margin-left: 15vw; /* Offset for asymmetry */
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .badge {
    background-color: var(--color-black);
    color: var(--color-cream);
    padding: 0.5rem 1.5rem;
    font-size: 2rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 4px solid var(--color-red);
    transform: rotate(-4deg);
    margin-bottom: 1.5rem;
    box-shadow: 8px 8px 0px var(--color-red);
  }

  .header {
    margin-bottom: 3rem;
  }

  .title {
    margin: 0;
    display: flex;
    flex-direction: column;
    line-height: 0.85;
    text-transform: uppercase;
  }

  .title .line {
    font-size: clamp(4rem, 12vw, 9rem);
    padding: 0 1rem;
    border: 6px solid var(--color-black);
  }

  .title .block-black {
    background-color: var(--color-black);
    color: var(--color-cream);
    align-self: flex-start;
  }

  .title .block-red {
    background-color: var(--color-red);
    color: var(--color-black);
    align-self: flex-start;
    margin-left: clamp(2rem, 5vw, 4rem);
    margin-top: -0.2em; /* Superposición típica del estilo */
  }

  /* Bloque de Contenido */
  .content-block {
    display: flex;
    align-items: flex-start;
    margin-bottom: 4rem;
    max-width: 650px;
    background-color: var(--color-cream);
    border: 6px solid var(--color-black);
    padding: 2rem;
    box-shadow: 15px 15px 0px var(--color-red);
    position: relative;
  }

  /* Cinta de precaución sutil encima de la caja */
  .content-block::before {
    content: "";
    position: absolute;
    top: -6px;
    left: -6px;
    width: calc(100% + 12px);
    height: 15px;
    background: repeating-linear-gradient(
      45deg,
      var(--color-black),
      var(--color-black) 10px,
      var(--color-cream) 10px,
      var(--color-cream) 20px
    );
    border-bottom: 6px solid var(--color-black);
  }

  .icon-arrow {
    width: 0;
    height: 0;
    border-top: 25px solid transparent;
    border-bottom: 25px solid transparent;
    border-left: 40px solid var(--color-red);
    margin-right: 2rem;
    margin-top: 0.5rem;
    flex-shrink: 0;
  }

  .text-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .description {
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.1;
    margin: 0;
    text-transform: uppercase;
  }

  .description .highlight {
    color: var(--color-red);
    background-color: var(--color-black);
    padding: 0 0.5rem;
    display: inline-block;
  }

  .sub-description {
    font-size: 1.2rem;
    line-height: 1.3;
    margin: 0;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    font-weight: bold;
    text-transform: uppercase;
    color: var(--color-dark-gray);
  }

  /* Pie con barra de progreso cruda */
  .footer-block {
    width: 100%;
    max-width: 700px;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
  }

  .progress-track {
    width: 100%;
    height: 40px;
    background-color: var(--color-cream);
    border: 6px solid var(--color-black);
    position: relative;
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    width: 75%;
    background-color: var(--color-red);
    border-right: 6px solid var(--color-black);
    background-image: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 15px,
      rgba(26, 26, 26, 0.3) 15px,
      rgba(26, 26, 26, 0.3) 30px
    );
    animation: slide-stripes 2s infinite linear;
  }

  @keyframes slide-stripes {
    0% {
      background-position: 0 0;
    }
    100% {
      background-position: 42px 0;
    }
  }

  .status-badge {
    background-color: var(--color-black);
    color: var(--color-cream);
    padding: 0.5rem 1rem;
    font-size: 1.5rem;
    letter-spacing: 0.05em;
    border-left: 10px solid var(--color-red);
  }

  @media (max-width: 900px) {
    .main-container {
      margin-left: 5vw;
    }
    .shape-thick-bar {
      display: none;
    }
    .title .block-red {
      margin-left: 1rem;
    }
  }

  @media (max-width: 600px) {
    .main-container {
      margin-left: 0;
      padding: 1rem;
    }
    .content-block {
      flex-direction: column;
    }
    .icon-arrow {
      transform: rotate(90deg);
      margin-bottom: 1rem;
    }
  }
</style>
