---
import { SITE_TITLE } from "../../consts";
import "../../styles/elegant.css";
---

<div class="construct-wrapper">
  <div class="main-container">
    <div class="badge">AVISO</div>

    <header class="header">
      <h1 class="title">
        <span class="line block-white">SITIO EN</span>
        <span class="line block-black">CONSTRUCCIÓN</span>
      </h1>
    </header>

    <div class="content-block">
      <div class="text-content">
        <p class="description">
          AQUÍ SE CONSTRUYE LA REVISTA <span class="highlight"
            >{SITE_TITLE}</span
          >.
        </p>
        <p class="sub-description">
          LO QUE NO PUEDE FALTAR EN LA CARTERA DE LA DAMA NI EL BOLSILLO DEL
          VARÓN. COSMOPOLITICAN, TU REVISTA CON CLASE.
        </p>
      </div>
    </div>

    <div class="footer-block">
      <div class="status-badge">ESTAMOS TRABAJANDO PARA USTED</div>
    </div>
  </div>
</div>

<style>
  .construct-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: #fff;
    color: #000;
    font-family: var(--c-font-heading);
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    box-sizing: border-box;
  }

  .main-container {
    position: relative;
    z-index: 10;
    width: 90%;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .badge {
    background-color: #000;
    color: #fff;
    padding: 0.5rem 1.5rem;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    border: 1px solid #000;
    margin-bottom: 2rem;
    font-family: var(--c-font-body);
  }

  .header {
    margin-bottom: 3rem;
  }

  .title {
    margin: 0;
    display: flex;
    flex-direction: column;
    line-height: 1;
    text-transform: uppercase;
  }

  .title .line {
    font-size: clamp(3rem, 10vw, 7rem);
    padding: 0.5rem 1rem;
    border: 1px solid #000;
  }

  .title .block-white {
    background-color: #fff;
    color: #000;
  }

  .title .block-black {
    background-color: #000;
    color: #fff;
    margin-top: -1px;
  }

  .content-block {
    margin-bottom: 4rem;
    max-width: 600px;
    border: 1px solid #000;
    padding: 2rem;
    background-color: #fff;
  }

  .text-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .description {
    font-size: 1.5rem;
    line-height: 1.2;
    margin: 0;
    text-transform: uppercase;
  }

  .description .highlight {
    background-color: #000;
    color: #fff;
    padding: 0 0.5rem;
    font-style: italic;
  }

  .sub-description {
    font-size: 1rem;
    line-height: 1.5;
    margin: 0;
    font-family: var(--c-font-body);
    font-weight: 500;
    text-transform: uppercase;
    color: #666;
    letter-spacing: 0.1em;
  }

  .footer-block {
    width: 100%;
    max-width: 400px;
  }

  .progress-track {
    width: 100%;
    height: 10px;
    background-color: #eee;
    border: 1px solid #000;
    margin-bottom: 1rem;
  }

  .progress-fill {
    height: 100%;
    width: 75%;
    background-color: #000;
  }

  .status-badge {
    font-size: 1rem;
    letter-spacing: 0.1em;
    font-family: var(--c-font-body);
    text-transform: uppercase;
  }
</style>
