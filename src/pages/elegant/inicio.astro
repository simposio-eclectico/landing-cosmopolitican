---
import ElegantLayout from "../../layouts/ElegantLayout.astro";
---

<ElegantLayout title="Inicio - Cosmopolitican">
  <div class="hero-section">
    <span class="block-header">Nueva era</span>

    <div class="massive-title">
      <div class="ornament-bg">C</div>
      <span class="line line-1">Tu revista</span>
      <span class="line line-2">CON CLASE</span>
      <span class="line line-3">Cosmopolitican</span>
    </div>

    <div class="divider"></div>

    <p class="hero-text">
      Lo que no puede faltar en la cartera de <em>la dama</em>
      ni el bolsillo del <em>varón</em>. Tu revista con clase.
    </p>

    <a href="/elegant/revista" class="cta-button">
      Leer la revista
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M5 12h14M12 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>
</ElegantLayout>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&display=swap");

  .hero-section {
    font-family: "EB Garamond", Georgia, serif;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 2.5rem 3.5rem;
    position: relative;
  }

  .block-header {
    font-size: 0.78rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #8a7f72;
    border-top: 1px solid #c8bfb0;
    padding-top: 0.75rem;
    margin-bottom: 2.5rem;
    display: inline-block;
  }

  .massive-title {
    position: relative;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
  }

  .ornament-bg {
    position: absolute;
    right: 0;
    top: 0;
    font-family: "Playfair Display", serif;
    font-size: clamp(6rem, 18vw, 14rem);
    font-weight: 900;
    font-style: italic;
    color: #ede8e0;
    line-height: 1;
    user-select: none;
    pointer-events: none;
    z-index: 0;
  }

  .line {
    font-family: "Playfair Display", serif;
    line-height: 0.88;
    display: block;
    position: relative;
    z-index: 1;
  }

  .line-1 {
    font-size: clamp(2.8rem, 9vw, 7rem);
    font-weight: 400;
    font-style: italic;
    color: #5a4f43;
  }

  .line-2 {
    font-size: clamp(3.5rem, 12vw, 9.5rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    padding: 0.1em 0;
    color: var(--c-black, #1a1714);
  }

  .line-3 {
    font-size: clamp(1.4rem, 4vw, 3rem);
    font-weight: 400;
    font-style: italic;
    color: #8a7f72;
    letter-spacing: 0.02em;
  }

  .divider {
    width: 80px;
    height: 1px;
    background: #c8bfb0;
    margin-bottom: 2rem;
  }

  .hero-text {
    font-family: "EB Garamond", serif;
    font-size: clamp(1.1rem, 2.2vw, 1.35rem);
    line-height: 1.75;
    color: #4a4239;
    max-width: 560px;
    margin-bottom: 2.5rem;
    font-style: italic;
  }

  .hero-text em {
    font-style: normal;
    font-weight: 500;
    color: #1a1714;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: "EB Garamond", serif;
    font-size: 0.85rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--c-bg);
    text-decoration: none;
    border: 1px solid currentColor;
    padding: 0.85rem 2rem;
    transition:
      background 0.2s,
      color 0.2s;
  }

  .cta-button:hover {
    background: var(--c-warm);
    color: var(--c-black);
  }
</style>
