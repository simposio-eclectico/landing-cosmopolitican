---
import ElegantLayout from '../../layouts/ElegantLayout.astro';
import { getCollection } from 'astro:content';
import { CATEGORIES, SECTIONS } from '../../consts';

const revistas = await getCollection('revista');
const sortedRevistas = revistas.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryKeys = Object.keys(CATEGORIES) as Array<keyof typeof CATEGORIES>;
---

<ElegantLayout title="Revista - Cosmopolitican">
  <div class="revista-header">
    <div class="block-header" style="transform: rotate(var(--c-rotate));">ARCHIVOS & EDICIONES</div>
    
    <div class="filter-container">
      <div class="filter-categories">
        <button class="filter-btn category-btn active" data-category="all">Todos</button>
        {categoryKeys.map((key) => (
          <button class="filter-btn category-btn" data-category={CATEGORIES[key]}>{CATEGORIES[key]}</button>
        ))}
      </div>
      
      <div class="filter-sections" style="display: none;">
        <!-- Sub-sections will be populated by JS when a category is clicked -->
      </div>
    </div>

    <div class="archive-grid">
      {sortedRevistas.map((post) => (
        <article 
          class={`issue-card ${post.data.theme !== 'default' ? post.data.theme : ''}`.trim()}
          data-category={post.data.category || ''}
          data-section={post.data.section || ''}
        >
          <div class="issue-number">{post.data.issueNumber}</div>
          <h2>{post.data.title}</h2>
          <p>{post.data.summary}</p>
          <a href={`/elegant/revista/${post.data.slug || post.id}`} style="text-decoration: none; align-self: flex-start; margin-top: auto; display: inline-block;">
            <button class="cta-button" style={post.data.customStyles}>{post.data.buttonText}</button>
          </a>
        </article>
      ))}
    </div>
  </div>
</ElegantLayout>

<style>
  .revista-header {
    max-width: 1200px;
    margin: 0 auto;
  }

  .filter-container {
    margin-top: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
  }

  .filter-categories, .filter-sections {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .filter-btn {
    background: transparent;
    color: var(--c-black);
    border: var(--c-brutalist-border);
    padding: 0.5rem 1.5rem;
    font-family: var(--c-font-heading);
    font-weight: 700;
    font-size: 1.3rem;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow: var(--c-brutalist-shadow);
    transition: all 0.2s ease;
  }

  :global(.theme-elegant) .filter-btn {
    box-shadow: none;
    border-width: 1px;
  }

  .filter-btn:hover {
    transform: translate(-3px, -3px);
    box-shadow: 8px 8px 0 var(--c-black);
  }

  .filter-btn.active {
    background-color: var(--c-black);
    color: var(--c-bg);
  }

  .filter-sections .filter-btn {
    font-size: 1.1rem;
    font-weight: 600;
    border-width: 3px;
    box-shadow: 4px 4px 0 var(--c-black);
    padding: 0.4rem 1.2rem;
  }

  .filter-sections .filter-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--c-black);
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 3rem;
    margin-top: 3rem;
  }

  .issue-card {
    background-color: var(--c-bg);
    border: var(--c-brutalist-border);
    padding: 2.5rem;
    box-shadow: var(--c-brutalist-shadow);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
    position: relative;
    overflow: hidden;
  }

  .issue-card::before {
    content: '';
    position: absolute;
    top: -20px;
    right: -20px;
    width: 60px;
    height: 60px;
    background-color: var(--c-red);
    transform: rotate(45deg);
    border-bottom: var(--c-brutalist-border);
  }

  :global(.theme-elegant) .issue-card::before {
    display: none;
  }

  .issue-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 16px 16px 0 var(--c-red);
  }

  .issue-card.featured {
    grid-column: 1 / -1;
    background-color: var(--c-red);
    box-shadow: var(--c-brutalist-shadow);
    border: var(--c-brutalist-border);
  }

  :global(.theme-elegant) .issue-card.featured {
    background-color: var(--c-bg);
    color: var(--c-black);
    box-shadow: none;
    border-width: 1px;
  }

  .issue-card.featured::before {
    background-color: var(--c-bg);
    width: 100px;
    height: 100px;
  }

  .issue-card.dark {
    background-color: var(--c-black);
    color: var(--c-bg);
    border-color: var(--c-red);
    box-shadow: 12px 12px 0 var(--c-red);
  }

  .issue-card.dark::before {
    background-color: var(--c-bg);
  }

  .issue-number {
    font-size: 4rem;
    font-family: var(--c-font-heading);
    color: transparent;
    -webkit-text-stroke: 2px var(--c-black);
    line-height: 1;
    margin-bottom: 1rem;
    letter-spacing: -0.05em;
  }

  .issue-card.featured .issue-number {
    font-size: 6rem;
  }

  .issue-card.dark .issue-number {
    -webkit-text-stroke: 2px var(--c-bg);
  }

  .issue-card h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    border-bottom: var(--c-brutalist-border);
    border-width: 2px;
    padding-bottom: 0.5rem;
    line-height: 1.1;
  }

  .issue-card.featured h2 {
    font-size: 4rem;
  }

  .issue-card p {
    flex: 1;
    font-size: 1.2rem;
    margin-bottom: 2rem;
  }

  .issue-card .cta-button {
    align-self: flex-start;
    margin-top: auto;
  }
</style>

<script define:vars={{ SECTIONS }}>
  document.addEventListener('DOMContentLoaded', () => {
    const categoryBtns = document.querySelectorAll('.category-btn');
    const sectionsContainer = document.querySelector('.filter-sections');
    const issueCards = document.querySelectorAll('.issue-card');

    let currentCategory = 'all';
    let currentSection = 'all';

    function renderSections(category) {
      if (category === 'all' || !SECTIONS[category]) {
        sectionsContainer.style.display = 'none';
        return;
      }
      
      sectionsContainer.style.display = 'flex';
      sectionsContainer.innerHTML = `<button class="filter-btn section-btn active" data-section="all">Todas</button>`;
      
      SECTIONS[category].forEach(sec => {
        const btn = document.createElement('button');
        btn.className = 'filter-btn section-btn';
        btn.dataset.section = sec;
        btn.textContent = sec;
        sectionsContainer.appendChild(btn);
      });

      // Bind events to new section buttons
      document.querySelectorAll('.section-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          document.querySelectorAll('.section-btn').forEach(b => b.classList.remove('active'));
          e.target.classList.add('active');
          currentSection = e.target.dataset.section;
          filterCards();
        });
      });
    }

    function filterCards() {
      issueCards.forEach(card => {
        const cardCat = card.dataset.category;
        const cardSec = card.dataset.section;

        const categoryMatch = currentCategory === 'all' || cardCat === currentCategory;
        const sectionMatch = currentSection === 'all' || cardSec === currentSection;

        if (categoryMatch && sectionMatch) {
          card.style.display = 'flex';
        } else {
          card.style.display = 'none';
        }
      });
    }

    categoryBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));
        e.target.classList.add('active');
        currentCategory = e.target.dataset.category;
        currentSection = 'all';
        renderSections(currentCategory);
        filterCards();
      });
    });
  });
</script>
