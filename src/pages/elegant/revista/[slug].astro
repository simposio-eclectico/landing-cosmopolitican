---
import { getCollection, render } from 'astro:content';
import ElegantLayout from "../../../layouts/ElegantLayout.astro";

export async function getStaticPaths() {
  const revistas = await getCollection('revista');
  return revistas.map(post => ({
    params: { slug: post.data.slug || post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<ElegantLayout title={`${post.data.title} - Cosmopolitican`}>
  <div class="article-container">
    <div class="block-header">{post.data.section.toUpperCase()}</div>
    
    <header class="article-header">
      <div class="issue-number">{post.data.issueNumber}</div>
      <h1>{post.data.title}</h1>
      <div class="metadata">
        <span>POR {post.data.author.toUpperCase()}</span>
        <span class="separator">/</span>
        <span>{post.data.pubDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
      </div>
    </header>

    <div class="article-content" style="padding-bottom: 4rem;">
      <Content />
    </div>
  </div>
</ElegantLayout>

<style>
  .article-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  .article-header {
    border-bottom: 6px solid var(--c-black);
    padding-bottom: 2rem;
    margin-bottom: 3rem;
  }

  .issue-number {
    font-size: 2rem;
    font-family: 'Oswald', sans-serif;
    color: var(--c-red);
    margin-bottom: 1rem;
  }

  .article-header h1 {
    font-size: 4rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    word-break: break-word;
  }

  .metadata {
    font-family: 'Oswald', sans-serif;
    font-size: 1.2rem;
    color: var(--c-black);
  }

  .separator {
    color: var(--c-red);
    margin: 0 0.5rem;
  }

  .article-content {
    font-size: 1.3rem;
    line-height: 1.6;
  }

  .article-content :global(h1), 
  .article-content :global(h2), 
  .article-content :global(h3) {
    font-family: 'Oswald', sans-serif;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .article-content :global(h1) {
    font-size: 2.5rem;
  }
  
  .article-content :global(h2) {
    font-size: 2rem;
  }
  
  .article-content :global(p) {
    margin-bottom: 1.5rem;
  }
  
  .article-content :global(a) {
    color: var(--c-red);
    text-decoration: underline;
    text-underline-offset: 4px;
    font-weight: 700;
  }

  .article-content :global(img) {
    max-width: 100%;
    height: auto;
    border: 4px solid var(--c-black);
    box-shadow: 8px 8px 0 var(--c-black);
    margin: 2rem 0;
  }

  .article-content :global(blockquote) {
    border-left: 6px solid var(--c-red);
    padding-left: 1.5rem;
    margin-left: 0;
    font-style: italic;
    color: #444;
  }
</style>
