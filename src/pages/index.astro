---
import BaseHead from "../components/BaseHead.astro";
import { SITE_DESCRIPTION, SITE_TITLE, SHOW_UNDER_CONSTRUCTION } from "../consts";
import UnderConstruction from "../components/UnderConstruction.astro";
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead
			title={SITE_TITLE + " - " + SITE_DESCRIPTION}
			description={SITE_DESCRIPTION}
		/>
		<style>
			html,
			body {
				margin: 0;
				padding: 0;
				width: 100vw;
				height: 100vh;
				overflow: hidden;
				background-color: #000;
			}
			.video-container {
				min-width: 100%;
				width: 100%;
				height: 100%;
				position: relative;
				display: flex;
				justify-content: center;
				align-items: center;
				margin: 0;
				padding: 0;
			}
			#bg-video {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
		</style>
	</head>
	<body>
		{SHOW_UNDER_CONSTRUCTION ? (
			<UnderConstruction />
		) : (
			<main class="video-container">
				<video id="bg-video" autoplay loop playsinline></video>
				<button
					id="unmute-btn"
					style="display: none; position: absolute; bottom: 30px; right: 30px; z-index: 10; padding: 12px 24px; background: rgba(0,0,0,0.6); color: white; border: 1px solid rgba(255,255,255,0.3); border-radius: 8px; font-family: system-ui, sans-serif; font-size: 16px; cursor: pointer; backdrop-filter: blur(4px); transition: all 0.3s ease;"
					onmouseover="this.style.background='rgba(0,0,0,0.9)'; this.style.borderColor='rgba(255,255,255,0.6)';"
					onmouseout="this.style.background='rgba(0,0,0,0.6)'; this.style.borderColor='rgba(255,255,255,0.3)';"
				>
					🔊
				</button>
			</main>
		)}

		<script>
			const videoList = ["/videos/2026-03-28%20At%2014.42.26.m4v"];

			const randomIndex = Math.floor(Math.random() * videoList.length);
			const selectedVideoSrc = videoList[randomIndex];

			const videoElement = document.getElementById("bg-video");

			const unmuteBtn = document.getElementById("unmute-btn");

			if (videoElement instanceof HTMLVideoElement) {
				videoElement.src = selectedVideoSrc;
				videoElement.muted = false; // Intentamos reproducir con sonido
				videoElement.load();

				const playPromise = videoElement.play();
				if (playPromise !== undefined) {
					playPromise.catch((error) => {
						console.error(
							"Autoplay was prevented by the browser:",
							error,
						);
						// Fallback: reproducir silenciado y mostrar botón para activar sonido
						videoElement.muted = true;
						videoElement.play();

						if (unmuteBtn) {
							unmuteBtn.style.display = "block";
							unmuteBtn.addEventListener("click", () => {
								videoElement.muted = false;
								unmuteBtn.style.display = "none";
							});
						}
					});
				}
			}
		</script>
	</body>
</html>
